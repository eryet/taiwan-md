const mindmapNodes = [
  {
    id: 'center',
    name: '🇹🇼 Taiwan Resources',
    label: '🇹🇼 Taiwan Resources',
    group: 'center',
    size: 20,
    color: '#065f46',
  },
];

heroData.categories.forEach((cat) => {
  mindmapNodes.push({
    id: cat.id,
    name: cat.label,
    label: cat.label,
    group: cat.id,
    size: 15,
    color: cat.color,
    url: '',
  });

  cat.sites.forEach((site, index) => {
    mindmapNodes.push({
      id: `${cat.id}_${index}`,
      name: site.name,
      label: site.name,
      group: cat.id,
      size: 8,
      color: cat.color,
      url: site.url,
    });
  });
});

const mindmapData = JSON.stringify({
  nodes: mindmapNodes,
  links: [], // D3.js will generate links based on hierarchy
});
